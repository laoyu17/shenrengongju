@startuml
!theme plain
left to right direction
skinparam componentStyle rectangle

package "Entry" {
  [CLI\nrtos-sim run\ncmd_run()] as CLI
  [UI\nRunController + SimulationWorker] as UI
}

package "IO" {
  [ConfigLoader] as Loader
  [ModelSpec] as Spec
}

package "Core Runtime" {
  [SimEngine] as Engine
  [Scheduler Factory\ncreate_scheduler()] as SFactory
  [Protocol Factory\ncreate_protocol()] as PFactory
  [ETM Factory\ncreate_etm()] as EFactory
  [Overhead Factory\ncreate_overhead_model()] as OFactory
  [IScheduler impl] as Scheduler
  [IResourceProtocol impl] as Protocol
  [IExecutionTimeModel impl] as ETM
  [IOverheadModel impl] as Overhead
}

package "Event & Analysis" {
  [EventBus] as Bus
  [CoreMetrics] as Metrics
  [Model Relations\nbuild_model_relations_report()] as Relations
  [Audit\nbuild_audit_report()] as Audit
}

package "Artifacts" {
  [artifacts/events.jsonl] as EventsFile
  [artifacts/metrics.json] as MetricsFile
  [artifacts/audit.json] as AuditFile
  [UI Gantt + Metrics Panel] as UIPanel
}

CLI --> Loader : load()
UI --> Loader : load_data()
Loader --> Spec
CLI --> Engine : build(spec)\nrun(until)
UI --> Engine : build/step/run via worker
Spec --> Engine

Engine --> SFactory
Engine --> PFactory
Engine --> EFactory
Engine --> OFactory
SFactory --> Scheduler
PFactory --> Protocol
EFactory --> ETM
OFactory --> Overhead

Engine --> Bus : publish(event)
Bus --> Metrics : consume(event)
Engine --> UIPanel : events_batch\nfinished_report
Engine --> CLI : events / metric_report()

Spec --> Relations
CLI --> Audit : build_audit_report(events, ...) 
Relations --> Audit : model_relation_summary

CLI --> EventsFile : write_jsonl(events)
CLI --> MetricsFile : write_json(metrics)
Audit --> AuditFile : write_json(audit)

note bottom of Bus
Truth source:
Event stream + exported artifacts
end note

@enduml
